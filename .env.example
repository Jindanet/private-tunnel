# Server Ports
WS_PORT=8080
DASHBOARD_PORT=8081
PROXY_PORT=8082

# Domains
# Primary domain serves the admin UI and client WebSocket endpoint
PRIMARY_DOMAIN=ex.example.com

# Tunnel domain is used for generated public tunnels
# You can keep it the same as PRIMARY_DOMAIN or use a cleaner split like tunnel.ex.example.com
# For multiple publish domains or root-host publishing, add them later from the admin UI.
TUNNEL_DOMAIN=tunnel.ex.example.com

# Tunnel Authentication
# Clients must supply this token to connect. Leave empty to disable auth (open server).
# Generate a strong token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TUNNEL_TOKEN=your-secret-token-here

# Dashboard
# If omitted on first boot, PrivateTunnel generates a random bootstrap password and saves it under DATA_DIR.
DASHBOARD_PASSWORD=your-password-here

# TCP Tunnel Port Range
TCP_PORT_MIN=30000
TCP_PORT_MAX=40000

# Data Directory
# Used for runtime artifacts such as the bootstrap admin password file.
DATA_DIR=./data

# Database Backend
# Primary storage backend: mysql or sqlite
DB_PROVIDER=mysql

# Optional mirror backends, comma-separated. Example: sqlite or sqlite,mysql
DB_SYNC_TARGETS=sqlite

# When false, the primary backend stays online even if a mirror write fails.
DB_SYNC_STRICT=false

# When true, empty mirror backends are bootstrapped automatically from the first backend that already has data.
DB_BOOTSTRAP_SYNC=true

# SQLite
SQLITE_PATH=./data/tunnel.db

# MySQL
# PrivateTunnel auto-creates the database if the MySQL user has permission.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=privatetunnel
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=privatetunnel

# Backward-compatible alias for older setups
# DB_PATH=./data/tunnel.db
