# Server Ports
WS_PORT=8080
DASHBOARD_PORT=8081
PROXY_PORT=8082

# Domain
DOMAIN=ex.example.com

# Tunnel Authentication
# Clients must supply this token to connect. Leave empty to disable auth (open server).
# Generate a strong token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TUNNEL_TOKEN=your-secret-token-here

# Dashboard
DASHBOARD_PASSWORD=your-password-here

# TCP Tunnel Port Range
TCP_PORT_MIN=30000
TCP_PORT_MAX=40000

# Database
DB_PATH=./data/tunnel.db
